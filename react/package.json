{
  "name": "resim-demo",
  "version": "0.1.1",
  "description": "Showcase app for the Resim Rust and WebAssembly image-processing library",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:wasm": "wasm-pack build ../rust --target web --out-dir pkg --release",
    "build": "npm run build:wasm && webpack --config webpack.config.js",
    "start": "npm run build:wasm && webpack serve --config webpack.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinansonmez/resim.git"
  },
  "keywords": [
    "webassembly",
    "wasm",
    "rust",
    "webpack"
  ],
  "author": "Sinan Sonmez",
  "license": "(MIT OR Apache-2.0)",
  "bugs": {
    "url": "https://github.com/sinansonmez/resim/issues"
  },
  "homepage": "https://github.com/sinansonmez/resim#readme",
  "devDependencies": {
    "copy-webpack-plugin": "^5.0.0",
    "webpack": "5.89.0",
    "webpack-cli": "4.10.0",
    "webpack-dev-server": "4.15.1"
  },
  "dependencies": {
    "@babel/preset-env": "^7.23.2",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^8.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
